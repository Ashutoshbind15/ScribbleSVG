{
  "name": "@scribblesvg/react-utils",
  "version": "0.1.0",
  "description": "React components for diagram display and editing - DiagramCanvas editor and DiagramRenderer read-only view",
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./renderer": {
      "types": "./dist/diagram-renderer.d.ts",
      "import": "./dist/diagram-renderer.js",
      "default": "./dist/diagram-renderer.js"
    },
    "./colors": {
      "types": "./dist/colors.d.ts",
      "import": "./dist/colors.js",
      "default": "./dist/colors.js"
    },
    "./editor": {
      "types": "./dist/editor/index.d.ts",
      "import": "./dist/editor/index.js",
      "default": "./dist/editor/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "keywords": [
    "react",
    "svg",
    "diagram",
    "scribble",
    "hand-drawn",
    "canvas",
    "editor",
    "renderer"
  ],
  "author": "Bind Ashutosh Parasnath <91549538+Ashutoshbind15@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ashutoshbind15/ScribbleSVG.git",
    "directory": "packages/react-utils"
  },
  "homepage": "https://github.com/Ashutoshbind15/ScribbleSVG#readme",
  "bugs": {
    "url": "https://github.com/Ashutoshbind15/ScribbleSVG/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@scribblesvg/core": "workspace:*",
    "lucide-react": "1.7.0"
  },
  "devDependencies": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.2"
  }
}
