{
  "name": "@scribblesvg/core",
  "version": "0.2.0",
  "description": "Diagram types, geometry, validation, and SVG rendering primitives with a hand-drawn scribble style",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build",
    "test": "pnpm --workspace-root run test",
    "typecheck": "tsc --project tsconfig.json --noEmit"
  },
  "keywords": [
    "svg",
    "diagram",
    "scribble",
    "hand-drawn",
    "sketch"
  ],
  "author": "Bind Ashutosh Parasnath <91549538+Ashutoshbind15@users.noreply.github.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ashutoshbind15/ScribbleSVG.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Ashutoshbind15/ScribbleSVG#readme",
  "bugs": {
    "url": "https://github.com/Ashutoshbind15/ScribbleSVG/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "6.0.2"
  },
  "dependencies": {
    "roughjs": "4.6.6",
    "zod": "4.3.6"
  }
}
